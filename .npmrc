# npm safe defaults — aligned with docker-security/safe-defaults
# https://github.com/docker-security/safe-defaults
#
# Requires npm >= 11.10.0 for min-release-age (silently ignored on older versions).

# --- Supply Chain Protection ---

# Refuse packages published less than 3 days ago.
# Most supply chain attacks are caught within 24-72 hours.
min-release-age=3

# Block all pre/post install scripts from dependencies.
# Override per-install with: npm install --ignore-scripts=false
ignore-scripts=true

# --- Integrity & Reproducibility ---

package-lock=true
save-exact=true

# --- Audit & Vulnerability Scanning ---

audit=true
audit-level=high

# --- TLS & Registry Security ---

strict-ssl=true
registry=https://registry.npmjs.org/
